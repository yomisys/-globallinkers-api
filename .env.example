# ============================================================
# GLOBAL LINKERS LTD — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=globallinkers
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_SSL=false

# Set DB_SSL=true and configure your SSL cert for production

# JWT Authentication
JWT_SECRET=change-this-to-a-long-random-secret-minimum-32-chars
JWT_EXPIRES_IN=12h

# Frontend URL (for CORS — set to your frontend domain in production)
FRONTEND_URL=http://localhost:3000

# ============================================================
# PRODUCTION CHECKLIST:
# ✅ Change JWT_SECRET to a cryptographically random 64-char string
# ✅ Set NODE_ENV=production
# ✅ Set DB_SSL=true
# ✅ Set FRONTEND_URL to your actual frontend domain
# ✅ Use a strong DB_PASSWORD
# ✅ Change the default admin password immediately after first login
# ============================================================
